generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Assignment {
  id          Int              @id @default(autoincrement())
  workerId    Int
  machineId   Int
  operationId Int
  shiftId     Int
  assignedBy  String?
  assignedAt  DateTime         @default(now())
  releasedAt  DateTime?
  status      AssignmentStatus @default(ACTIVE)
  remarks     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  machine     Machine          @relation(fields: [machineId], references: [id])
  operation   Operation        @relation(fields: [operationId], references: [id])
  shift       Shift            @relation(fields: [shiftId], references: [id])
  worker      Worker           @relation(fields: [workerId], references: [id])
  attendances Attendance[]

  @@map("assignments")
}

model Attendance {
  id             Int            @id @default(autoincrement())
  workerId       Int
  assignmentId   Int
  terminalId     Int
  machineId      Int
  shiftId        Int
  attendanceType AttendanceType
  tapTime        DateTime       @default(now())
  status         RecordStatus   @default(ACTIVE)
  createdAt      DateTime       @default(now())
  assignment     Assignment     @relation(fields: [assignmentId], references: [id])
  machine        Machine        @relation(fields: [machineId], references: [id])
  shift          Shift          @relation(fields: [shiftId], references: [id])
  terminal       Terminal       @relation(fields: [terminalId], references: [id])
  worker         Worker         @relation(fields: [workerId], references: [id])

  @@map("attendances")
}

model Bundle {
  id                 Int                   @id @default(autoincrement())
  bundleNumber       String                @unique
  productionOrderId  Int
  currentOperationId Int?
  currentMachineId   Int?
  currentWorkerId    Int?
  quantity           Int
  completedQuantity  Int                   @default(0)
  status             BundleStatus          @default(CREATED)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  stageLogs          BundleStageLog[]
  tagAssignments     BundleTagAssignment[]
  currentMachine     Machine?              @relation(fields: [currentMachineId], references: [id])
  currentOperation   Operation?            @relation(fields: [currentOperationId], references: [id])
  currentWorker      Worker?               @relation(fields: [currentWorkerId], references: [id])
  productionOrder    ProductionOrder       @relation(fields: [productionOrderId], references: [id])
  productionTasks    ProductionTask[]
  qcCheckLogs        QCCheckLog[]

  @@map("bundles")
}

model Department {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  name            String           @unique
  description     String?
  status          RecordStatus     @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  machines        Machine[]
  operations      Operation[]
  productionTasks ProductionTask[]
  workers         Worker[]

  @@map("departments")
}

model MachineType {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  name        String
  description String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  machines    Machine[]

  @@map("machine_types")
}

model Machine {
  id                          Int                          @id @default(autoincrement())
  machineCode                 String                       @unique
  machineName                 String
  departmentId                Int
  machineTypeId               Int
  terminalId                  Int                          @unique
  status                      RecordStatus                 @default(ACTIVE)
  remarks                     String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  positionIndex               Int?
  roomId                      Int?
  rowIndex                    Int?
  assignments                 Assignment[]
  attendances                 Attendance[]
  bundles                     Bundle[]
  machineOperationAssignments MachineOperationAssignment[]
  department                  Department                   @relation(fields: [departmentId], references: [id])
  machineType                 MachineType                  @relation(fields: [machineTypeId], references: [id])
  room                        Room?                        @relation(fields: [roomId], references: [id])
  terminal                    Terminal                     @relation(fields: [terminalId], references: [id])
  productionTasks             ProductionTask[]

  @@unique([roomId, rowIndex, positionIndex])
  @@map("machines")
}

model Operation {
  id                          Int                          @id @default(autoincrement())
  operationCode               String                       @unique
  operationName               String                       @unique
  description                 String?
  standardMinuteValue         Float
  displayOrder                Int                          @default(0)
  status                      RecordStatus                 @default(ACTIVE)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  requiredSkillId             Int?
  departmentId                Int?
  assignments                 Assignment[]
  stageLogs                   BundleStageLog[]
  bundles                     Bundle[]
  machineOperationAssignments MachineOperationAssignment[]
  department                  Department?                  @relation(fields: [departmentId], references: [id])
  requiredSkill               Skill?                       @relation(fields: [requiredSkillId], references: [id])
  productionTasks             ProductionTask[]
  qcCheckLogs                 QCCheckLog[]

  @@map("operations")
}

model ProductionOrder {
  id                Int              @id @default(autoincrement())
  orderNumber       String           @unique
  buyerName         String
  styleNumber       String
  styleName         String
  color             String
  size              String
  plannedQuantity   Int
  completedQuantity Int              @default(0)
  priority          Int              @default(0)
  plannedStartDate  DateTime
  plannedEndDate    DateTime
  status            OrderStatus      @default(PLANNED)
  remarks           String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  bundles           Bundle[]
  productionTasks   ProductionTask[]

  @@map("production_orders")
}

model Shift {
  id                          Int                          @id @default(autoincrement())
  shiftCode                   String                       @unique
  shiftName                   String                       @unique
  startTime                   String
  endTime                     String
  breakStart                  String?
  breakEnd                    String?
  workingHours                Float
  status                      RecordStatus                 @default(ACTIVE)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  assignments                 Assignment[]
  attendances                 Attendance[]
  machineOperationAssignments MachineOperationAssignment[]
  productionTasks             ProductionTask[]

  @@map("shifts")
}

model Skill {
  id           Int           @id @default(autoincrement())
  code         String        @unique
  name         String
  description  String?
  status       RecordStatus  @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  operations   Operation[]
  workerSkills WorkerSkill[]

  @@map("skills")
}

model Terminal {
  id              Int          @id @default(autoincrement())
  terminalCode    String       @unique
  serialNumber    String?
  ipAddress       String?
  firmwareVersion String?
  status          RecordStatus @default(ACTIVE)
  lastHeartbeat   DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  macAddress      String?
  terminalName    String?
  attendances     Attendance[]
  machine         Machine?

  @@map("terminals")
}

model WorkerGrade {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  name        String
  description String?
  priority    Int
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workers     Worker[]

  @@map("worker_grades")
}

model WorkerSkill {
  id        Int      @id @default(autoincrement())
  workerId  Int
  skillId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  skill     Skill    @relation(fields: [skillId], references: [id])
  worker    Worker   @relation(fields: [workerId], references: [id])

  @@unique([workerId, skillId])
  @@map("worker_skills")
}

model Worker {
  id                Int              @id @default(autoincrement())
  employeeCode      String           @unique
  nfcCardId         String           @unique
  firstName         String
  lastName          String
  gender            String?
  phone             String?
  email             String?
  dateOfBirth       DateTime?
  joiningDate       DateTime?
  departmentId      Int
  gradeId           Int
  status            RecordStatus     @default(ACTIVE)
  remarks           String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  assignments       Assignment[]
  attendances       Attendance[]
  stageLogsOperated BundleStageLog[] @relation("StageLogOperator")
  bundles           Bundle[]
  productionTasks   ProductionTask[]
  qcChecksPerformed QCCheckLog[]     @relation("QCCheckPerson")
  qcChecksAudited   QCCheckLog[]     @relation("QCCheckedWorker")
  skills            WorkerSkill[]
  department        Department       @relation(fields: [departmentId], references: [id])
  grade             WorkerGrade      @relation(fields: [gradeId], references: [id])

  @@map("workers")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ProductionTask {
  id                Int             @id @default(autoincrement())
  taskId            String          @unique
  productionOrderId Int
  bundleId          Int?
  operationId       Int
  departmentId      Int
  machineId         Int?
  workerId          Int?
  shiftId           Int?
  priority          Int             @default(0)
  estimatedTime     Int
  targetQuantity    Int
  status            TaskStatus      @default(CREATED)
  supervisor        String?
  remarks           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  actualEnd         DateTime?
  actualStart       DateTime?
  scheduledEnd      DateTime?
  scheduledStart    DateTime?
  completedQuantity Int             @default(0)
  sequenceOrder     Int             @default(0)
  bundle            Bundle?         @relation(fields: [bundleId], references: [id])
  department        Department      @relation(fields: [departmentId], references: [id])
  machine           Machine?        @relation(fields: [machineId], references: [id])
  operation         Operation       @relation(fields: [operationId], references: [id])
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id])
  shift             Shift?          @relation(fields: [shiftId], references: [id])
  worker            Worker?         @relation(fields: [workerId], references: [id])

  @@map("production_tasks")
}

model BundleTagAssignment {
  id         Int              @id @default(autoincrement())
  tagCode    String           @unique
  bundleId   Int?
  assignedAt DateTime?
  releasedAt DateTime?
  status     TagStatus        @default(AVAILABLE)
  assignedBy String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  stageLogs  BundleStageLog[]
  bundle     Bundle?          @relation(fields: [bundleId], references: [id])
  qcChecks   QCCheckLog[]

  @@map("bundle_tag_assignments")
}

model BundleStageLog {
  id          Int                 @id @default(autoincrement())
  bundleId    Int
  tagId       Int
  operationId Int
  operatorId  Int
  inTime      DateTime            @default(now())
  outTime     DateTime?
  remarks     String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  bundle      Bundle              @relation(fields: [bundleId], references: [id])
  operation   Operation           @relation(fields: [operationId], references: [id])
  operator    Worker              @relation("StageLogOperator", fields: [operatorId], references: [id])
  tag         BundleTagAssignment @relation(fields: [tagId], references: [id])

  @@map("bundle_stage_logs")
}

model QCCheckLog {
  id             Int                  @id @default(autoincrement())
  bundleId       Int
  tagId          Int?
  qcPersonId     Int
  qcTier         QCTier
  operationId    Int?
  workerId       Int?
  status         QCCheckStatus
  defectNotes    String?
  checkedAt      DateTime             @default(now())
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  passQuantity   Int                  @default(0)
  rejectQuantity Int                  @default(0)
  reworkQuantity Int                  @default(0)
  bundle         Bundle               @relation(fields: [bundleId], references: [id])
  operation      Operation?           @relation(fields: [operationId], references: [id])
  qcPerson       Worker               @relation("QCCheckPerson", fields: [qcPersonId], references: [id])
  tag            BundleTagAssignment? @relation(fields: [tagId], references: [id])
  worker         Worker?              @relation("QCCheckedWorker", fields: [workerId], references: [id])

  @@map("qc_check_logs")
}

model MachineOperationAssignment {
  id          Int          @id @default(autoincrement())
  machineId   Int
  operationId Int
  shiftId     Int
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  machine     Machine      @relation(fields: [machineId], references: [id])
  operation   Operation    @relation(fields: [operationId], references: [id])
  shift       Shift        @relation(fields: [shiftId], references: [id])

  @@unique([machineId, shiftId])
  @@map("machine_operation_assignments")
}

model Floor {
  id          Int          @id @default(autoincrement())
  factoryName String?
  name        String
  floorNumber Int          @unique
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rooms       Room[]

  @@map("floors")
}

model Room {
  id             Int          @id @default(autoincrement())
  floorId        Int
  name           String
  roomType       String?
  rowsCount      Int          @default(3)
  status         RecordStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  machinesPerRow Int          @default(35)
  machines       Machine[]
  floor          Floor        @relation(fields: [floorId], references: [id])

  @@map("rooms")
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
}

enum AttendanceType {
  IN
  OUT
}

enum BundleStatus {
  CREATED
  IN_PROGRESS
  WAITING
  COMPLETED
  QC_COMPLETED
  REWORK
  HOLD
}

enum OrderStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum TransactionType {
  CREATE
  START
  COMPLETE
  TRANSFER
  HOLD
  REWORK
  QC
  FINISHED
}

enum TaskStatus {
  CREATED
  PLANNED
  ASSIGNED
  ACCEPTED
  RUNNING
  COMPLETED
  CLOSED
}

enum TagStatus {
  AVAILABLE
  ASSIGNED
}

enum QCTier {
  LINE_QC
  FINAL_QC
}

enum QCCheckStatus {
  PASS
  FAIL
  REWORK
}
