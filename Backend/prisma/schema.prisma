generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Assignment {
  id          Int              @id @default(autoincrement())
  workerId    Int
  machineId   Int
  operationId Int
  shiftId     Int
  assignedBy  String?
  assignedAt  DateTime         @default(now())
  releasedAt  DateTime?
  status      AssignmentStatus @default(ACTIVE)
  remarks     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  machine     Machine          @relation(fields: [machineId], references: [id])
  operation   Operation        @relation(fields: [operationId], references: [id])
  shift       Shift            @relation(fields: [shiftId], references: [id])
  worker      Worker           @relation(fields: [workerId], references: [id])
  attendances Attendance[]

  @@map("assignments")
}

model Attendance {
  id             Int            @id @default(autoincrement())
  workerId       Int
  assignmentId   Int
  terminalId     Int
  machineId      Int
  shiftId        Int
  attendanceType AttendanceType
  tapTime        DateTime       @default(now())
  status         RecordStatus   @default(ACTIVE)
  createdAt      DateTime       @default(now())
  assignment     Assignment     @relation(fields: [assignmentId], references: [id])
  machine        Machine        @relation(fields: [machineId], references: [id])
  shift          Shift          @relation(fields: [shiftId], references: [id])
  terminal       Terminal       @relation(fields: [terminalId], references: [id])
  worker         Worker         @relation(fields: [workerId], references: [id])

  @@map("attendances")
}



model Bundle {
  id                 Int                   @id @default(autoincrement())
  bundleNumber       String                @unique
  productionOrderId  Int
  currentOperationId Int?
  currentMachineId   Int?
  currentWorkerId    Int?
  quantity           Int
  completedQuantity  Int                   @default(0)
  status             BundleStatus          @default(CREATED)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  currentMachine     Machine?              @relation(fields: [currentMachineId], references: [id])
  currentOperation   Operation?            @relation(fields: [currentOperationId], references: [id])
  currentWorker      Worker?               @relation(fields: [currentWorkerId], references: [id])
  productionOrder    ProductionOrder       @relation(fields: [productionOrderId], references: [id])

  productionTasks    ProductionTask[]
  tagAssignments     BundleTagAssignment[]
  stageLogs          BundleStageLog[]
  qcCheckLogs        QCCheckLog[]

  @@map("bundles")
}

model Department {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  name            String           @unique
  description     String?
  status          RecordStatus     @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  machines        Machine[]
  workers         Worker[]
  productionTasks ProductionTask[]
  operations      Operation[]

  @@map("departments")
}

model MachineType {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  name        String
  description String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  machines    Machine[]

  @@map("machine_types")
}

model Machine {
  id                            Int                          @id @default(autoincrement())
  machineCode                   String                       @unique
  machineName                   String
  departmentId                  Int
  machineTypeId                 Int
  terminalId                    Int                          @unique
  status                        RecordStatus                 @default(ACTIVE)
  remarks                       String?
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  assignments                   Assignment[]
  attendances                   Attendance[]


  bundles                       Bundle[]
  department                    Department                   @relation(fields: [departmentId], references: [id])
  machineType                   MachineType                  @relation(fields: [machineTypeId], references: [id])
  terminal                      Terminal                     @relation(fields: [terminalId], references: [id])
  roomId                        Int?
  rowIndex                      Int?
  positionIndex                 Int?
  room                          Room?                        @relation(fields: [roomId], references: [id])

  productionTasks               ProductionTask[]
  machineOperationAssignments   MachineOperationAssignment[]

  @@unique([roomId, rowIndex, positionIndex])
  @@map("machines")
}

model Operation {
  id                              Int                          @id @default(autoincrement())
  operationCode                   String                       @unique
  operationName                   String                       @unique
  description                     String?
  standardMinuteValue             Float
  displayOrder                    Int                          @default(0)
  departmentId                    Int?
  status                          RecordStatus                 @default(ACTIVE)
  createdAt                       DateTime                     @default(now())
  updatedAt                       DateTime                     @updatedAt
  assignments                     Assignment[]


  bundles                         Bundle[]
  productionTasks                 ProductionTask[]
  stageLogs                       BundleStageLog[]
  qcCheckLogs                     QCCheckLog[]
  requiredSkillId                 Int?
  requiredSkill                   Skill?                       @relation(fields: [requiredSkillId], references: [id])
  machineOperationAssignments     MachineOperationAssignment[]
  department                      Department?                  @relation(fields: [departmentId], references: [id])

  @@map("operations")
}

model ProductionOrder {
  id                 Int                 @id @default(autoincrement())
  orderNumber        String              @unique
  buyerName          String
  styleNumber        String
  styleName          String
  color              String
  size               String
  plannedQuantity    Int
  completedQuantity  Int                 @default(0)
  priority           Int                 @default(0)
  plannedStartDate   DateTime
  plannedEndDate     DateTime
  status             OrderStatus         @default(PLANNED)
  remarks            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  bundles            Bundle[]
  productionTasks    ProductionTask[]

  @@map("production_orders")
}



model Shift {
  id                          Int                          @id @default(autoincrement())
  shiftCode                   String                       @unique
  shiftName                   String                       @unique
  startTime                   String
  endTime                     String
  breakStart                  String?
  breakEnd                    String?
  workingHours                Float
  status                      RecordStatus                 @default(ACTIVE)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  assignments                 Assignment[]
  attendances                 Attendance[]
  productionTasks             ProductionTask[]
  machineOperationAssignments MachineOperationAssignment[]

  @@map("shifts")
}

model Skill {
  id           Int           @id @default(autoincrement())
  code         String        @unique
  name         String
  description  String?
  status       RecordStatus  @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workerSkills WorkerSkill[]
  operations   Operation[]

  @@map("skills")
}

model Terminal {
  id              Int          @id @default(autoincrement())
  terminalCode    String       @unique
  serialNumber    String?
  ipAddress       String?
  firmwareVersion String?
  status          RecordStatus @default(ACTIVE)
  lastHeartbeat   DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  macAddress      String?
  terminalName    String?
  attendances     Attendance[]
  machine         Machine?

  @@map("terminals")
}

model WorkerGrade {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  name        String
  description String?
  priority    Int
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workers     Worker[]

  @@map("worker_grades")
}

model WorkerSkill {
  id        Int      @id @default(autoincrement())
  workerId  Int
  skillId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  skill     Skill    @relation(fields: [skillId], references: [id])
  worker    Worker   @relation(fields: [workerId], references: [id])

  @@unique([workerId, skillId])
  @@map("worker_skills")
}

model Worker {
  id                           Int                 @id @default(autoincrement())
  employeeCode                 String              @unique
  nfcCardId                    String              @unique
  firstName                    String
  lastName                     String
  gender                       String?
  phone                        String?
  email                        String?
  dateOfBirth                  DateTime?
  joiningDate                  DateTime?
  departmentId                 Int
  gradeId                      Int
  status                       RecordStatus        @default(ACTIVE)
  remarks                      String?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  assignments                  Assignment[]
  attendances                  Attendance[]


  bundles                      Bundle[]

  skills                       WorkerSkill[]
  department                   Department          @relation(fields: [departmentId], references: [id])
  grade                        WorkerGrade         @relation(fields: [gradeId], references: [id])
  productionTasks              ProductionTask[]
  stageLogsOperated            BundleStageLog[]    @relation("StageLogOperator")
  qcChecksPerformed            QCCheckLog[]        @relation("QCCheckPerson")
  qcChecksAudited              QCCheckLog[]        @relation("QCCheckedWorker")

  @@map("workers")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
}

enum AttendanceType {
  IN
  OUT
}

enum BundleStatus {
  CREATED
  IN_PROGRESS
  WAITING
  COMPLETED
  QC_COMPLETED
  REWORK
  HOLD
}

enum OrderStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum TransactionType {
  CREATE
  START
  COMPLETE
  TRANSFER
  HOLD
  REWORK
  FINISHED
  QC
}

model ProductionTask {
  id                Int        @id @default(autoincrement())
  taskId            String     @unique
  productionOrderId Int
  bundleId          Int?
  operationId       Int
  departmentId      Int
  machineId         Int?
  workerId          Int?
  shiftId           Int?
  priority          Int        @default(0)
  estimatedTime     Int // In minutes
  targetQuantity    Int
  completedQuantity Int        @default(0)
  sequenceOrder     Int        @default(0)
  status            TaskStatus @default(CREATED)
  supervisor        String?
  scheduledStart    DateTime?
  scheduledEnd      DateTime?
  actualStart       DateTime?
  actualEnd         DateTime?
  remarks           String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id])
  bundle          Bundle?         @relation(fields: [bundleId], references: [id])
  operation       Operation       @relation(fields: [operationId], references: [id])
  department      Department      @relation(fields: [departmentId], references: [id])
  machine         Machine?        @relation(fields: [machineId], references: [id])
  worker          Worker?         @relation(fields: [workerId], references: [id])
  shift           Shift?          @relation(fields: [shiftId], references: [id])

  @@map("production_tasks")
}

enum TaskStatus {
  CREATED
  PLANNED
  ASSIGNED
  ACCEPTED
  RUNNING
  COMPLETED
  CLOSED
}

// ─── Tag Pool ────────────────────────────────────────────────────────────────

model BundleTagAssignment {
  id         Int       @id @default(autoincrement())
  tagCode    String    @unique
  bundleId   Int?
  assignedAt DateTime?
  releasedAt DateTime?
  status     TagStatus @default(AVAILABLE)
  assignedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  bundle Bundle? @relation(fields: [bundleId], references: [id])

  stageLogs BundleStageLog[]
  qcChecks  QCCheckLog[]

  @@map("bundle_tag_assignments")
}

// ─── Stage Scan Log ───────────────────────────────────────────────────────────

model BundleStageLog {
  id          Int       @id @default(autoincrement())
  bundleId    Int
  tagId       Int
  operationId Int
  operatorId  Int
  inTime      DateTime  @default(now())
  outTime     DateTime?
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bundle    Bundle              @relation(fields: [bundleId], references: [id])
  tag       BundleTagAssignment @relation(fields: [tagId], references: [id])
  operation Operation           @relation(fields: [operationId], references: [id])
  operator  Worker              @relation("StageLogOperator", fields: [operatorId], references: [id])

  @@map("bundle_stage_logs")
}

// ─── Two-Tier QC Check Log ────────────────────────────────────────────────────

model QCCheckLog {
  id          Int           @id @default(autoincrement())
  bundleId    Int
  tagId       Int?
  qcPersonId  Int
  qcTier      QCTier
  operationId Int?
  workerId    Int?
  status      QCCheckStatus
  defectNotes String?
  passQuantity   Int           @default(0)
  rejectQuantity Int           @default(0)
  reworkQuantity Int           @default(0)
  checkedAt   DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  bundle    Bundle               @relation(fields: [bundleId], references: [id])
  tag       BundleTagAssignment? @relation(fields: [tagId], references: [id])
  qcPerson  Worker               @relation("QCCheckPerson", fields: [qcPersonId], references: [id])
  operation Operation?           @relation(fields: [operationId], references: [id])
  worker    Worker?              @relation("QCCheckedWorker", fields: [workerId], references: [id])

  @@map("qc_check_logs")
}

// ─── New Enums ────────────────────────────────────────────────────────────────

enum TagStatus {
  AVAILABLE
  ASSIGNED
}

enum QCTier {
  LINE_QC
  FINAL_QC
}

enum QCCheckStatus {
  PASS
  FAIL
  REWORK
}

model MachineOperationAssignment {
  id          Int          @id @default(autoincrement())
  machineId   Int
  operationId Int
  shiftId     Int
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  machine     Machine      @relation(fields: [machineId], references: [id])
  operation   Operation    @relation(fields: [operationId], references: [id])
  shift       Shift        @relation(fields: [shiftId], references: [id])

  @@unique([machineId, shiftId])
  @@map("machine_operation_assignments")
}

// ─── Factory Layout ────────────────────────────────────────────────────────────

model Floor {
  id          Int          @id @default(autoincrement())
  factoryName String?
  name        String
  floorNumber Int
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rooms       Room[]

  @@unique([floorNumber])
  @@map("floors")
}

model Room {
  id             Int          @id @default(autoincrement())
  floorId        Int
  name           String
  roomType       String?
  rowsCount      Int          @default(3)
  machinesPerRow Int          @default(35)
  status         RecordStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  floor    Floor     @relation(fields: [floorId], references: [id])
  machines Machine[]

  @@map("rooms")
}
